# Matrix AI Sahayak — Environment Configuration
# Copy this file to .env and fill in actual values
# DO NOT commit .env to git

# ─── MySQL (Matrix Database — read-only user) ─────────────────────────────────
MYSQL_HOST=10.242.71.180
MYSQL_USER=readUser
MYSQL_PASSWORD=readUser@123
MYSQL_DATABASE=up_police_matrix

# ─── Matrix JWT (from Matrix app.properties — do not change) ─────────────────
MATRIX_JWT_SECRET=UPPOLICESOCIALMEDIAjfndfjkjfnkjnfkfjkdfjdfkjdskfjlskfjsldkfjslkdfjslkdfjslkdsklfjdUPPOLICE
MATRIX_JWT_ISSUER=socialMedia
MATRIX_JWT_AUDIENCE=socialMediaUsers

# ─── Qdrant Vector DB (local Docker — default values work) ────────────────────
QDRANT_HOST=localhost
QDRANT_PORT=6333

# ─── LLM Model (Llama 3 8B — download separately, ~4.5 GB) ───────────────────
# Download: huggingface.co/bartowski/Meta-Llama-3-8B-Instruct-GGUF
LLM_MODEL_PATH=/models/llama3/Meta-Llama-3-8B-Instruct.Q4_K_M.gguf
LLM_N_GPU_LAYERS=35

# ─── Email Notifications (SMTP — for daily report alerts) ────────────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=alerts@matrixupp.com
SMTP_PASSWORD=your_smtp_password_here
REPORT_EMAIL_RECIPIENTS=["sp@matrixupp.com","dig@matrixupp.com"]

# ─── App ──────────────────────────────────────────────────────────────────────
DEBUG=false
LOG_LEVEL=INFO
